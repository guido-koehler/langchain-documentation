# ── Azure AI Foundry ─────────────────────────────────────────────────────────────
# Found in Azure Portal → your Foundry project → Overview → Project endpoint
AZURE_AI_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>

# API key — only needed for local dev without `az login`.
# Leave blank (or omit) to authenticate via DefaultAzureCredential (recommended).
AZURE_AI_API_KEY=

# The name of your deployed Claude models inside the Foundry project.
# Primary model — used for complex tasks: code review, scaffolding, planning.
MODEL_DEPLOYMENT_NAME=claude-sonnet-4-6
# Mini model — used for fast, high-volume tasks: translation, summaries, CI analysis.
MODEL_MINI_DEPLOYMENT_NAME=claude-haiku-4-5

# ── LangSmith Tracing ────────────────────────────────────────────────────────────
# Get your key at https://smith.langchain.com → Settings → API Keys
# Set LANGSMITH_TRACING=false to disable tracing entirely.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__<your-langsmith-key>

# All runs will appear under this project in the LangSmith UI
LANGCHAIN_PROJECT=tj-sales-hello-world
